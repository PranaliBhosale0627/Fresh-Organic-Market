PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string. Required on Render.
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.example.mongodb.net/verdant_harvest?retryWrites=true&w=majority

# Optional if your MONGODB_URI does not include a database path.
MONGODB_DB=verdant_harvest

# Comma-separated deployed frontend origins allowed by CORS.
# Example: https://fresh-organic-frontend.vercel.app,https://your-netlify-site.netlify.app
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
